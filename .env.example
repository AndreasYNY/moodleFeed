# Optional: set this only if you want Vite's local dev proxy to avoid CORS.
# The app still asks for the Moodle URL on the login screen.
# Leave unset if your Moodle allows direct browser requests.
VITE_MOODLE_BASE_URL=https://moodle.example.edu

# Optional: production uses /api/moodle as a same-origin proxy by default.
# Set to "direct" only if you intentionally want browser-to-Moodle requests in production.
# VITE_MOODLE_PROXY=direct
